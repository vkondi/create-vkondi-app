{
  "name": "create-vkondi-app",
  "version": "1.0.0",
  "description": "Scaffold opinionated React or Next.js applications",
  "type": "module",
  "bin": {
    "create-vkondi-app": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "prepublishOnly": "yarn type-check && yarn lint && yarn test:run && yarn build",
    "qa": "yarn type-check && yarn lint && yarn format:check && yarn test:run",
    "type-check": "tsc --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:debug": "vitest --inspect-brk --inspect --single-thread",
    "prepare": "husky"
  },
  "keywords": [
    "cli",
    "scaffold",
    "react",
    "nextjs",
    "vite",
    "typescript"
  ],
  "author": "Vishwajeet Kondi <vishdevwork@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/vkondi/create-vkondi-app"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "ora": "^8.0.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.16",
    "@types/prompts": "^2.4.9",
    "@vitest/coverage-v8": "^1.0.4",
    "@vitest/ui": "^1.0.4",
    "husky": "^9.1.7",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  }
}
