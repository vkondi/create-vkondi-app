{
  "name": "create-scaffold-kit",
  "version": "0.0.6",
  "description": "Scaffold opinionated React or Next.js applications",
  "type": "module",
  "bin": {
    "create-scaffold-kit": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "release": "release-it",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major",
    "prepack": "node scripts/prepack.cjs",
    "postpack": "node scripts/postpack.cjs",
    "prepublishOnly": "yarn type-check && yarn lint && yarn test:run && yarn build",
    "qa": "yarn type-check && yarn lint && yarn format:check && yarn test:run",
    "type-check": "tsc --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:debug": "vitest --inspect-brk --inspect --single-thread",
    "prepare": "husky"
  },
  "keywords": [
    "cli",
    "scaffold",
    "react",
    "nextjs",
    "vite",
    "typescript"
  ],
  "author": "Vishwajeet Kondi <vishdevwork@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vkondi/create-scaffold-kit.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "fs-extra": "^11.2.0",
    "ora": "^9.3.0",
    "prompts": "^2.4.2"
  },
  "resolutions": {
    "undici": "^6.24.0",
    "picomatch": ">=2.3.2"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.16",
    "@types/prompts": "^2.4.9",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "husky": "^9.1.7",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "release-it": "^19.2.4",
    "tsup": "^8.0.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
